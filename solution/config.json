{
  "provider": "openai",
  "model": "gpt-4o-mini",
  "model_price_tier": "standard",
  "max_steps": 6,
  "loop_guard": true,
  "temperature": 0.15,
  "context_size": 2,
  "verbose_system": false,
  "timeout_ms": 30000,
  "max_completion_tokens": 420,
  "retry": {"enabled": true, "max_attempts": 3, "backoff_ms": 5000},
  "cache": {"enabled": true},
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 8,
  "tool_error_rate": 0.0,
  "catalog_override": {},
  "route_rules": [],
  "planner": false,
  "verify": true,
  "self_consistency": 1,
  "tool_budget": 4
}
